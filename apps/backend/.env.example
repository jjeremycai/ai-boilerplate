# WorkOS Authentication
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
